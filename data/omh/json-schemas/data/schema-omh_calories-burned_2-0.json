{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "This schema represents calories burned.",
  "type": "object",
  "properties": {
    "kcal_burned": {
      "allOf": [
        {"$ref": "https://w3id.org/ieee/ieee-1752-schema/unit-value-1.0.json"},
        {"properties": {"unit": {"enum": ["kcal"]}}}
      ]
    },
    "effective_time_frame": {
      "$ref": "https://w3id.org/ieee/ieee-1752-schema/time-frame-1.0.json"
    }
  },
  "required": ["kcal_burned", "effective_time_frame"]
}
