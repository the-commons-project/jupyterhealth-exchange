{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "This schema represents a sleep episode.",
  "type": "object",
  "properties": {
    "effective_time_frame": {
      "$ref": "https://w3id.org/ieee/ieee-1752-schema/time-frame-1.0.json"
    },
    "total_sleep_time": {
      "allOf": [
        {"$ref": "https://w3id.org/ieee/ieee-1752-schema/duration-unit-value-1.0.json"},
        {"properties": {"unit": {"enum": ["min", "sec", "h"]}}}
      ]
    },
    "sleep_maintenance_efficiency_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    }
  },
  "required": ["effective_time_frame"]
}
