DEBUG=True # Static assest will not be served locally eithout this set to True; set to False in production
SITE_URL="http://localhost:8000"

DB_NAME="jhe_dev"
DB_USER="jheuser"
DB_PASSWORD="jhepassword"
DB_HOST="localhost" # Use host.docker.internal if connecting to localhost from Docker
DB_PORT=5432

OIDC_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII... <output of: $ openssl genrsa -out oidc.key 4096> ...H67\n-----END PRIVATE KEY-----"

#  if unset a randomly generated value is used which will not work with more than one worker
SECRET_KEY=
# Open Wearables integration (used by core/views/ow.py and ow_poll command)
OW_API_URL="http://localhost:8001"
OW_API_KEY="sk-your-open-wearables-api-key"

# SMART on FHIR token exchange (cross-vendor provider SSO via /o/token-exchange).
# Validation is offline id_token + JWKS — no userinfo/introspection endpoint required.
# TRUSTED_TOKEN_ISSUERS — comma-separated list of trusted EHR OIDC issuer URLs (the id_token `iss`).
TRUSTED_TOKEN_ISSUERS=https://ehr-a.example/fhir,https://ehr-b.example/fhir
# TRUSTED_TOKEN_AUDIENCE — the SMART app's client_id registered at the EHR (the id_token `aud`).
TRUSTED_TOKEN_AUDIENCE=<smart-client-id registered at the EHR>
# TRUSTED_TOKEN_IDP — legacy single-issuer setting; still supported (auto-added to the issuer list).
# TRUSTED_TOKEN_IDP=https://ehr.example/fhir
